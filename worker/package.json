{
  "name": "tsf-translation-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Background worker for TSF translation v4 pipeline",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "npm run build --prefix ../packages/translation-core",
    "build": "tsc",
    "predev": "npm run build --prefix ../packages/translation-core",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "check:auto-translate-modules": "node scripts/check-auto-translate-modules.mjs",
    "probe:hint-queues": "node scripts/probe-hint-queues.mjs",
    "cleanup:stale-hints": "node scripts/cleanup-stale-hints.mjs",
    "cleanup:stale-hints:apply": "node scripts/cleanup-stale-hints.mjs --apply"
  },
  "dependencies": {
    "@ciwi/translation-core": "file:../packages/translation-core",
    "@azure/cosmos": "^4.9.3",
    "@azure/storage-blob": "^12.31.0",
    "@libsql/client": "^0.17.3",
    "ioredis": "^5.10.1",
    "node-html-parser": "^6.1.13",
    "tencentcloud-sdk-nodejs-ses": "^4.0.1038"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
