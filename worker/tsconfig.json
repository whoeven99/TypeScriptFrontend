{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@ciwi/translation-core": ["../packages/translation-core/dist/index.d.ts"],
      "@ciwi/translation-core/runtime": ["../packages/translation-core/dist/runtime.d.ts"],
      "@ciwi/translation-core/llm-translate": ["../packages/translation-core/dist/llmTranslate.d.ts"],
      "@ciwi/translation-core/sync-translate": ["../packages/translation-core/dist/syncTranslate.d.ts"],
      "@ciwi/translation-core/html-translate": ["../packages/translation-core/dist/htmlTranslate.d.ts"],
      "@ciwi/translation-core/json-extract-rules": ["../packages/translation-core/dist/jsonExtractRules.d.ts"],
      "@ciwi/translation-core/placeholder-mask": ["../packages/translation-core/dist/placeholderMask.d.ts"],
      "@ciwi/translation-core/target-language-prompt": ["../packages/translation-core/dist/targetLanguagePrompt.d.ts"],
      "@ciwi/translation-core/translate-quality": ["../packages/translation-core/dist/translateQuality.d.ts"],
      "@ciwi/translation-core/translation-field-limits": ["../packages/translation-core/dist/translationFieldLimits.d.ts"],
      "@ciwi/translation-core/translation-memory": ["../packages/translation-core/dist/translationMemory.d.ts"],
      "@ciwi/translation-core/translation-filter": ["../packages/translation-core/dist/translationFilter/index.d.ts"],
      "@ciwi/translation-core/translation-filter/*": ["../packages/translation-core/dist/translationFilter/*.d.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
