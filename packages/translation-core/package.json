{
  "name": "@ciwi/translation-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": ".build/index.js",
  "types": ".build/index.d.ts",
  "exports": {
    ".": {
      "types": "./.build/index.d.ts",
      "import": "./.build/index.js"
    },
    "./llm-translate": {
      "types": "./.build/llmTranslate.d.ts",
      "import": "./.build/llmTranslate.js"
    },
    "./sync-translate": {
      "types": "./.build/syncTranslate.d.ts",
      "import": "./.build/syncTranslate.js"
    },
    "./runtime": {
      "types": "./.build/runtime.d.ts",
      "import": "./.build/runtime.js"
    },
    "./translation-memory": {
      "types": "./.build/translationMemory.d.ts",
      "import": "./.build/translationMemory.js"
    },
    "./html-translate": {
      "types": "./.build/htmlTranslate.d.ts",
      "import": "./.build/htmlTranslate.js"
    },
    "./json-extract-rules": {
      "types": "./.build/jsonExtractRules.d.ts",
      "import": "./.build/jsonExtractRules.js"
    },
    "./placeholder-mask": {
      "types": "./.build/placeholderMask.d.ts",
      "import": "./.build/placeholderMask.js"
    },
    "./target-language-prompt": {
      "types": "./.build/targetLanguagePrompt.d.ts",
      "import": "./.build/targetLanguagePrompt.js"
    },
    "./translate-quality": {
      "types": "./.build/translateQuality.d.ts",
      "import": "./.build/translateQuality.js"
    },
    "./translation-field-limits": {
      "types": "./.build/translationFieldLimits.d.ts",
      "import": "./.build/translationFieldLimits.js"
    },
    "./translation-filter": {
      "types": "./.build/translationFilter/index.d.ts",
      "import": "./.build/translationFilter/index.js"
    },
    "./translation-filter/*": {
      "types": "./.build/translationFilter/*.d.ts",
      "import": "./.build/translationFilter/*.js"
    }
  },
  "files": [
    ".build"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.18.8",
    "typescript": "^5.9.3"
  }
}
