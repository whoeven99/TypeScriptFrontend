// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken            String?
  refreshTokenExpires     DateTime?
}

// 取代 Java `Translates` —— 每店一行的翻译配置 + 迁移开关
model ShopTranslationSettings {
  shop          String    @id              // myshopify 域名（Java shopName）
  primaryLocale String                     // 源语言（Java source），ex "en"
  targets       Json                       // 目标语言数组 string[]（Java 每 target 一行 → 合并）
  autoTranslate Boolean   @default(false)  // 自动增量翻译总开关（Java autoTranslate）
  migratedToTsf Boolean   @default(false)  // 不可逆：true 后只走 TSF
  migratedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([autoTranslate, migratedToTsf]) // worker 自动扫描用
}

// 每店每目标语言一行 —— 语言页的「按语言自动翻译开关」。worker 据此精确按语言建任务。
model ShopTargetLocale {
  id            Int      @id @default(autoincrement())
  shop          String                     // myshopify 域名
  locale        String                     // 目标语言（Shopify locale，如 "fr"）
  autoTranslate Boolean  @default(false)
  status        Int      @default(1)       // 预留：1=启用
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, locale])
  @@index([shop, autoTranslate])
}

// 取代 Java `Glossary`（字段对齐 Java GlossaryDO，便于术语表页面直接复用）
model Glossary {
  id            Int      @id @default(autoincrement()) // 与 Java 自增 id 一致，前端按数字 id 选择/删除
  shop          String                     // Java shopName
  sourceText    String
  targetText    String
  rangeCode     String?                    // 适用语言范围（Java rangeCode）
  caseSensitive Boolean  @default(false)   // Java Integer(0/1) → Boolean
  status        Int      @default(1)       // 1=启用 0=停用（Java status），worker 只注入启用的
  createdAt     DateTime @default(now())

  @@index([shop])
}

// 对应 Java WidgetConfigurations，每店一行
model SwitcherConfiguration {
  shop                  String   @id            // Java shop_name
  languageSelector      Boolean  @default(true)
  currencySelector      Boolean  @default(true)
  ipOpen                Boolean  @default(false)
  includedFlag          Boolean  @default(true)
  fontColor             String   @default("#000000")
  backgroundColor       String   @default("#ffffff")
  buttonColor           String   @default("#ffffff")
  buttonBackgroundColor String   @default("#000000")
  optionBorderColor     String   @default("#ccc")
  selectorPosition      String   @default("bottom_left")
  positionData          String   @default("10")
  isTransparent         Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// 对应 Java `Currencies`，用于货币页和 storefront currency switcher。
model Currency {
  id            Int      @id @default(autoincrement())
  shop          String                     // Java shop_name
  currencyName  String                     // Java currency_name
  currencyCode  String                     // ISO 4217 code
  rounding      String?
  exchangeRate  String?
  primaryStatus Int      @default(0)       // 1=默认币种，0=可切换币种
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([shop, currencyCode])
  @@index([shop])
  @@index([shop, primaryStatus])
}

// 原 Java Redis `bogda:rate` 缓存迁到 Turso；Fixer 当前以 EUR 为 base。
model CurrencyRate {
  currencyCode String   @id
  rate         Float
  base         String   @default("EUR")
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime
}

// 对应 Java User_IP_Redirection
model IpRedirection {
  id           Int      @id                    // 迁移时写入 Java id；新建时由应用层取 max+1
  shop         String
  region       String   @default("")
  languageCode String   @default("")
  currencyCode String   @default("")
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shop, isDeleted])
  @@index([shop, region])
}

// 取代 Java `User_Page_Fly`；Int 主键对齐 Java id，迁移时保留原值
model PageFlyTranslation {
  id           Int      @id
  shop         String
  sourceText   String
  targetText   String
  languageCode String
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shop, languageCode, isDeleted])
}

// 取代 Java `User_Liquid`
model LiquidRule {
  id                String   @id @default(cuid())
  shop              String                 // Java shopName
  beforeTranslation String                 // liquidBeforeTranslation
  afterTranslation  String                 // liquidAfterTranslation
  languageCode      String?
  replacementMethod Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shop])
}

// ─── 计费与 onboarding（Phase 0；新用户 Turso 账本，老用户仍走 Java）───

/// 店铺计费账户（每 shop 一行，存在即表示走 TSF 本地计费）。
model Account {
  id                 String   @id @default(cuid())
  shop               String   @unique
  subscriptionTokens Int      @default(0)
  purchasedTokens    Int      @default(0)
  trialTokens        Int      @default(0)
  usedTokens         Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  appSubscription    AppSubscription?
  periodUsages       AccountPeriodUsage[]
  billingLogs        BillingLog[]
  taskTokenUsageLogs TaskTokenUsageLog[]
}

/// 套餐 / 购包目录（种子见 prisma/billing-plan-catalog-seed.sql）。
model PlanCatalog {
  planKey         String   @id
  kind            String
  billingInterval String?
  displayName     String
  tokens          Int
  priceAmount     String
  currencyCode    String   @default("USD")
  trialDays       Int?
  shopifyPlanName String?
  sortOrder       Int      @default(0)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled, sortOrder])
}

/// 当前生效的 Shopify 订阅（每 shop 最多一条）。
model AppSubscription {
  id                    String    @id @default(cuid())
  shop                  String    @unique
  planKey               String
  shopifySubscriptionId String    @unique
  billingInterval       String
  status                String
  tokensPerPeriod       Int
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelledAt           DateTime?
  confirmationUrl       String?
  rawPayload            Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  account      Account              @relation(fields: [shop], references: [shop])
  periodUsages AccountPeriodUsage[]

  @@index([status])
}

/// 订阅周期用量归档（续费时写入）。
model AccountPeriodUsage {
  id                          String   @id @default(cuid())
  shop                        String
  appSubscriptionId           String
  planKey                     String
  periodStart                 DateTime
  periodEnd                   DateTime
  usedTokens                  Int
  subscriptionTokensAllocated Int
  purchasedTokensRemaining    Int      @default(0)
  trialTokensRemaining        Int      @default(0)
  archivedAt                  DateTime @default(now())

  account         Account         @relation(fields: [shop], references: [shop])
  appSubscription AppSubscription @relation(fields: [appSubscriptionId], references: [id])

  @@unique([appSubscriptionId, periodStart, periodEnd])
  @@index([shop, periodEnd])
}

/// 计费账务流水。
model BillingLog {
  id          String   @id @default(cuid())
  shop        String
  eventType   String
  planKey     String?
  referenceId String?
  tokensDelta Int?
  usedTokens  Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  account Account @relation(fields: [shop], references: [shop])

  @@index([shop, createdAt])
  @@index([eventType, createdAt])
  @@index([referenceId])
}

/// 翻译任务 token 消耗明细（仅翻译任务，含 taskType）。
model TaskTokenUsageLog {
  id           String   @id @default(cuid())
  shop         String
  taskType     String
  jobId        String?
  modelKey     String?
  rawTokens    Int
  billedTokens Int
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  createdAt    DateTime @default(now())

  account Account @relation(fields: [shop], references: [shop])

  @@index([shop, taskType, createdAt])
  @@index([shop, createdAt])
}

/// 翻译 LLM token 计费系数（种子见 prisma/token-billing-rule-seed.sql）。
model TokenBillingRule {
  ruleKey       String   @id
  feature       String
  modelKey      String
  displayName   String
  multiplier    Float
  baseTokenCost Int?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([feature, modelKey])
  @@index([feature, enabled])
}

/// 安装 / 卸载 / scope 变更（与 BillingLog 分离）。
model CommonEventLog {
  id          String   @id @default(cuid())
  shop        String
  eventType   String
  topic       String?
  referenceId String?
  payload     Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([shop, createdAt])
  @@index([eventType, createdAt])
  @@index([referenceId])
}

/// 取代 Java `Users` 店铺元数据。
model ShopProfile {
  shop             String   @id
  email            String?
  firstName        String?
  lastName         String?
  userTag          String?
  defaultThemeId   String?
  defaultThemeName String?
  defaultLanguage  String?
  accessToken      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// 取代 Java `User_AILanguagePacks`（默认 General 包）。
model ShopLanguagePack {
  shop      String   @id
  packKey   String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
