{
  "include": ["env.d.ts", "**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "removeComments": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@ciwi/translation-core": ["./packages/translation-core/.build/index.d.ts"],
      "@ciwi/translation-core/runtime": ["./packages/translation-core/.build/runtime.d.ts"],
      "@ciwi/translation-core/llm-translate": ["./packages/translation-core/.build/llmTranslate.d.ts"],
      "@ciwi/translation-core/sync-translate": ["./packages/translation-core/.build/syncTranslate.d.ts"],
      "@ciwi/translation-core/html-translate": ["./packages/translation-core/.build/htmlTranslate.d.ts"],
      "@ciwi/translation-core/json-extract-rules": ["./packages/translation-core/.build/jsonExtractRules.d.ts"],
      "@ciwi/translation-core/placeholder-mask": ["./packages/translation-core/.build/placeholderMask.d.ts"],
      "@ciwi/translation-core/target-language-prompt": ["./packages/translation-core/.build/targetLanguagePrompt.d.ts"],
      "@ciwi/translation-core/translate-quality": ["./packages/translation-core/.build/translateQuality.d.ts"],
      "@ciwi/translation-core/translation-field-limits": ["./packages/translation-core/.build/translationFieldLimits.d.ts"],
      "@ciwi/translation-core/translation-memory": ["./packages/translation-core/.build/translationMemory.d.ts"],
      "@ciwi/translation-core/translation-filter": ["./packages/translation-core/.build/translationFilter/index.d.ts"],
      "@ciwi/translation-core/translation-filter/*": ["./packages/translation-core/.build/translationFilter/*.d.ts"]
    },
    "types": ["node"]
  }
}
