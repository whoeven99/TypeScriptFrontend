{% assign language_iso = localization.language.iso_code %}
<link rel="stylesheet" href="{{ 'switcher.css' | asset_url }}">

{% comment %}
  预连接 Java 后端：域名与 ciwi-api.js switchUrl(blockId) 保持一致。
  仅 preconnect 当前 block 实际会请求的源，避免线上误连 Test 域名。
{% endcomment %}
{% assign ciwi_java_backend = 'https://springbackendservice-e3hgbjgqafb9cpdh.canadacentral-01.azurewebsites.net' %}
{% if block.id == 'AZnlHVkxkZDMwNDg2Q__13411448604249213220' %}
  {% assign ciwi_java_backend = 'https://springbackendprod.azurewebsites.net' %}
{% endif %}
<link rel="preconnect" href="{{ ciwi_java_backend }}" crossorigin>
<link rel="dns-prefetch" href="{{ ciwi_java_backend }}">

<div dir="{% if language_iso == 'ar' or language_iso == 'fa' or language_iso == 'ur' or language_iso == 'he' %}rtl{% else %}ltr{% endif %}">
  <ciwiswitcher-form>
    {% form 'localization' %}
      <div
        id="ciwi-container"
        class="ciwi_container"
      >
        <div
          id="selector-box"
          class="selector_box"
          style="display: none;"
        >
          <div class="close_button_wrapper">
            <button class="selector_box_close_button" id="selector-box-close-button">
              <svg
                t="1759129501675"
                class="icon"
                viewBox="0 0 1024 1024"
                version="1.1"
                xmlns="http://www.w3.org/2000/svg"
                p-id="4794"
                width="16"
                height="16"
              >
                <path d="M567.7 509.8l253.2-253.2c12.3-12.3 12.3-32.1 0-44.4a31.325 31.325 0 0 0-44.4 0L523.3 465.4 270.1 212.2a31.325 31.325 0 0 0-44.4 0 31.325 31.325 0 0 0 0 44.4l253.2 253.2L225.7 763a31.325 31.325 0 0 0 0 44.4c6.1 6.1 14.2 9.2 22.2 9.2s16.1-3.1 22.2-9.2l253.2-253.2 253.2 253.2c6.1 6.1 14.2 9.2 22.2 9.2s16.1-3.1 22.2-9.2c12.3-12.3 12.3-32.1 0-44.4L567.7 509.8z" fill="#2c2c2c" p-id="4795"></path>
              </svg>
            </button>
          </div>
          <div
            id="language-switcher-container"
            style="display: none"
          >
            <div class="native-selector language-native-selector">
              <img
                id="language-selector-flag"
                class="selector-language-flag"
                alt=""
                hidden
                src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
                onerror="this.style.display='none'"
              >
              <select
                class="switcher-native-select language_selector_header"
                data-type="language"
                aria-label="Select language"
              >
                {% for language in localization.available_languages %}
                  <option
                    value="{{ language.iso_code }}"
                    {% if language.iso_code == localization.language.iso_code %}
                      selected
                    {% endif %}
                  >
                    {{- language.endonym_name | capitalize -}}
                  </option>
                {% endfor %}
              </select>
              <ul
                class="ciwi-custom-dropdown"
                id="language-custom-dropdown"
                style="display: none;"
                role="listbox"
                aria-label="Select language"
              ></ul>
            </div>
          </div>
          <div
            id="currency-switcher-container"
            style="display: none"
          >
            <div class="native-selector">
              <select
                class="switcher-native-select currency_selector_header"
                data-type="currency"
                aria-label="Select currency"
              ></select>
            </div>
          </div>
        </div>
        <div
          id="selector-backdrop"
          class="selector_backdrop"
          style="display: none;"
        ></div>
        <div
          id="main-box"
          class="ciwi_main_box"
          style="display: none; text-align: center; justify-content: center;"
        >
          <img
            id="main-language-flag"
            class="country-flag main_box_flag"
            alt=""
            width="20px"
            height="auto"
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
            onerror="this.style.display='none'"
            style="margin-right: 8px; flex-shrink: 0;"
          >
          <span
            id="display-text"
            class="main_box_text"
            style="text-align: center; flex: 1;"
          >
            {{- localization.language.endonym_name | capitalize -}}
          </span>
          <img
            id="mainbox-arrow-icon"
            class="mainarrow_icon"
            src="{{ 'arrow.svg' | asset_url }}"
            alt="Arrow Icon"
            width="20"
            height="20"
          >
        </div>
        <div
          id="translate-float-btn"
          style="
            display: none;
            width: 30px;
            pointer-events: auto;
            position: absolute;
            height: 140px;
            align-items: center;
            z-index: 9999999999;
            transition:
            opacity 0.3s,
            transform 0.3s;
            cursor: pointer;
          "
        >
          <div
            id="translate-float-btn-text"
            style="
              display: block;
              padding: 0px 20px 0px 20px;
              font-size: 14px;
              line-height: 30px;
              height: 30px;
              font-weight: 700;
              overflow: hidden;
              transform: rotate(90deg);
              transform-origin: right top;
              position: absolute;
              white-space: nowrap;
              max-width: 400px;
              user-select: none;
            "
          >
            <span>Translate</span>
          </div>
          <img
            id="translate-float-btn-icon"
            class="translate_float_btn_icon"
            alt=""
            width="28"
            height="20"
            hidden
            src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
            onerror="this.style.display='none'"
            style="
              border-radius: 3px;
              box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
              position: relative;
            "
          >
        </div>
      </div>
      <input id="queryCiwiId" type="hidden" value="{{ shop.permanent_domain }}">
      <input type="hidden" id="ciwiAppProxyBase" value="{{ shop.url }}/apps/ciwi">
      {%- comment -%}
        Java 后端地址单一来源：与上方 preconnect 同源（ciwi_java_backend）。
        ciwi-api.js switchUrl() 优先读取本输入，避免 JS 与 Liquid 两处硬编码漂移。
      {%- endcomment -%}
      <input type="hidden" id="ciwiJavaBackend" value="{{ ciwi_java_backend }}">
      <input id="queryMoneyFormat" type="hidden" value="{{ shop.money_format | strip_html }}">
      <input type="hidden" name="currency_code" value="{{ localization.country.currency.iso_code }}">
      <input type="hidden" name="language_code" value="{{ localization.language.iso_code }}">
      <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
      <input type="hidden" name="iptoken" value="4edc3b4d5ca1476accda4d9912c99112">
      <input type="hidden" name="product_id" value="{{ product.id }}">
      <input type="hidden" name="page_type" value="{{ request.page_type }}">
      <input type="hidden" name="template_name" value="{{ template.name }}">
      <input type="hidden" name="block_id" value="{{ block.id }}">
      <input type="hidden" id="ciwiLocaleDataUrl" value="{{ 'language-locale-data.js' | asset_url }}">
    {% endform %}
  </ciwiswitcher-form>
  <ciwiswitcher-form>
    {% form 'localization' %}
      <div hidden>
        <ul role="list">
          {%- for country in localization.available_countries -%}
            <li>
              <a
                href="#"
                data-value="{{ country.iso_code }}"
                {% if country.iso_code == localization.country.iso_code %}
                  aria-current="true"
                {% endif %}
              >
                {{- country.name }} |
                {{ country.currency.iso_code }}
                {{ country.currency.symbol -}}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {% endform %}
  </ciwiswitcher-form>

  {% comment %}
    数据脚本改用 defer（原为 async）：defer 保证在 DOMContentLoaded 之前按文档顺序执行完，
    与 type=module 的 ciwi-main.js 一起在 DCL 前就绪，避免 main 读取 window.countryCurMap 等出现竞态。
    这样 ciwi-main 可以在 DOMContentLoaded 启动，而不必等待整页 load。
  {% endcomment %}
  {% comment %}
    language-locale-data.js（约 24KB，仅用于国旗）改为按需加载：
    不在此处 eager 加载，由 ciwi-main 在浏览器空闲或用户首次接触切换器时
    通过 #ciwiLocaleDataUrl 动态注入，避免每页关键路径都下载它。
  {% endcomment %}
  <script src="{{ 'currency-format-config.js' | asset_url }}" defer></script>
  <script src="{{ 'country-cur-map.js' | asset_url }}" defer></script>
  <script type="module" src="{{ 'ciwi-main.js' | asset_url }}"></script>
  <script>
    window.__JS_EXECUTED__ = true;
  </script>
</div>

{% schema %}
{
  "name": "Ciwi_Switcher",
  "target": "body"
}
{% endschema %}
